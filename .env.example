# =====================================================================
# Gay I Club NYC — environment variables
# Copy to .env (or .env.local) and fill in. .env is gitignored.
# Set the same values in your Netlify project under Site settings →
# Environment variables for the deployed site.
# =====================================================================

# --- Supabase --------------------------------------------------------
# Public URL + anon key (browser-safe). Service role MUST stay server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site --------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://gayiclub.com

# --- Concierge chat (existing OpenAI streaming) -----------------------
OPENAI_API_KEY=

# --- Reminder pipeline (Resend transport) -----------------------------
# When unset in dev, /lib/email logs to console instead of sending.
RESEND_API_KEY=
EMAIL_FROM="Gay I Club <noreply@gayiclub.com>"
CRON_SECRET=                         # openssl rand -hex 32

# --- Cortex → /api/news/ingest bridge ---------------------------------
# Cortex's club_publisher.py POSTs here with this bearer token.
NEWS_INGEST_SECRET=                  # openssl rand -hex 32

# --- Robot Benchmark frontier models ----------------------------------
# Each is optional independently; the /robot page gracefully marks any
# provider without a key as "unavailable" and still runs the others.
ANTHROPIC_API_KEY=                   # Claude Opus 4.7
GOOGLE_API_KEY=                      # Gemini 3.1 Pro
# OPENAI_API_KEY already set above   # GPT 5.5

# Model id overrides (only set if you need to pin to a specific snapshot).
ROBOT_MODEL_ANTHROPIC=claude-opus-4-7
ROBOT_MODEL_GOOGLE=gemini-3.1-pro
ROBOT_MODEL_OPENAI=gpt-5.5
